NODE_ENV=development
PORT=8080
MONGO_URI=mongodb://127.0.0.1:27017/pdf_replacement_tool
MONGO_MEMORY_FALLBACK=true
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
APP_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174
MAX_PDFS_PER_BATCH=50
MAX_PDF_SIZE_MB=25
LOW_CONFIDENCE_POLICY=review_required
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=storage
AI_MATCHING_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
AI_MATCH_TIMEOUT_MS=8000
AI_MAX_CANDIDATES=25
AI_DOCUMENT_TYPE_MIN_CONFIDENCE=0.7
OCR_ENABLED=true
OCR_LANG=eng
OCR_RENDER_SCALE=2
IN_MEMORY_QUEUE_CONCURRENCY=2
PDF_FILE_CONCURRENCY=3
MAX_ACTIVE_BATCHES_PER_USER=3
JOB_LOCK_TIMEOUT_MINUTES=30
STORAGE_RETENTION_HOURS=24
STORAGE_CLEANUP_INTERVAL_MINUTES=60
TRUST_PROXY=1
SOCKET_IO_ADAPTER=mongo
WEB_CONCURRENCY=1
